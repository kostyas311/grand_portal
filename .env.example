# NormBase Portal — Environment Variables
# Скопируй этот файл как .env и заполни значения

# === DATABASE ===
DATABASE_URL=postgresql://normbase:normbase_password@localhost:5432/normbase
POSTGRES_USER=normbase
POSTGRES_PASSWORD=normbase_password
POSTGRES_DB=normbase

# === JWT ===
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_64_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_STRONG_RANDOM_SECRET_64_CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# === FILE STORAGE ===
STORAGE_PATH=/app/storage
# Максимальный размер файла в байтах (500MB по умолчанию)
MAX_FILE_SIZE=524288000
# Лимит для ZIP on-the-fly сборки (500MB суммарно)
ZIP_SIZE_LIMIT=524288000

# === APP ===
NODE_ENV=production
API_PORT=3001
WEB_PORT=3000

# === FRONTEND ===
NEXT_PUBLIC_API_URL=http://localhost/api

# === ПЕРВЫЙ ADMIN (для seed скрипта) ===
ADMIN_EMAIL=admin@company.ru
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
ADMIN_FULL_NAME=Администратор системы
