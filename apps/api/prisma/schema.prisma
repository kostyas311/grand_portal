generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  MANAGER
  ADMIN
}

enum ThemePreference {
  LIGHT
  DARK
}

enum CardStatus {
  NEW
  IN_PROGRESS
  REVIEW
  DONE
  CANCELLED
}

enum CardPriority {
  OPTIONAL
  NORMAL
  URGENT
  CRITICAL
}

enum MaterialType {
  FILE
  EXTERNAL_LINK
}

enum WatchSource {
  AUTO
  MANUAL
}

enum HistoryAction {
  CREATED
  STATUS_CHANGED
  EXECUTOR_CHANGED
  REVIEWER_CHANGED
  SOURCE_MATERIAL_ADDED
  SOURCE_MATERIAL_REMOVED
  RESULT_ADDED
  RETURNED_WITH_ERRORS
  COMPLETED
  CANCELLED
  FIELD_UPDATED
}

enum NotificationType {
  ASSIGNMENT_CHANGED
  STATUS_CHANGED
  CARD_UPDATED
  REVIEW_REQUEST
  COMMENT_ADDED
  SOURCE_MATERIAL_ADDED
  RESULT_ADDED
  ADMIN_REQUEST_CREATED
  ADMIN_REQUEST_NEEDS_INFO
  ADMIN_REQUEST_REPLIED
  ADMIN_REQUEST_COMPLETED
  ADMIN_REQUEST_REJECTED
}

enum AdminRequestStatus {
  NEW
  CLARIFICATION_REQUIRED
  DONE
  REJECTED
}

enum InstructionStatus {
  DRAFT
  PUBLISHED
  HIDDEN
  ARCHIVED
}

enum SprintStatus {
  IN_PROGRESS
  CLOSED
}

model User {
  id           String    @id @default(uuid())
  fullName     String    @map("full_name")
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         UserRole  @default(USER)
  themePreference ThemePreference @default(LIGHT) @map("theme_preference")
  isActive     Boolean   @default(true) @map("is_active")
  position     String?
  phone        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  lastLoginAt  DateTime? @map("last_login_at")

  // Relations
  refreshTokens    RefreshToken[]
  createdCards     Card[]           @relation("CardCreator")
  executorCards    Card[]           @relation("CardExecutor")
  reviewerCards    Card[]           @relation("CardReviewer")
  lastChangedCards Card[]           @relation("CardLastChanger")
  sourceMaterials  SourceMaterial[]
  resultVersions   ResultVersion[]
  cardHistory      CardHistory[]
  reviewComments   ReviewComment[]
  createdSources   DataSource[]
  dataSourceInstructionLinks DataSourceInstruction[] @relation("DataSourceInstructionCreator")
  watchedCards     CardWatcher[]
  notifications    Notification[] @relation("NotificationRecipient")
  sentNotifications Notification[] @relation("NotificationActor")
  pendingNotifications PendingNotification[] @relation("PendingNotificationRecipient")
  pendingSentNotifications PendingNotification[] @relation("PendingNotificationActor")
  createdAdminRequests AdminRequest[] @relation("AdminRequestCreator")
  completedAdminRequests AdminRequest[] @relation("AdminRequestCompleter")
  rejectedAdminRequests AdminRequest[] @relation("AdminRequestRejector")
  adminRequestMessages AdminRequestMessage[]
  updatedNotificationEmailSettings NotificationEmailSettings[] @relation("NotificationEmailSettingsUpdatedBy")
  createdInstructionFolders InstructionFolder[] @relation("InstructionFolderCreator")
  instructions Instruction[] @relation("InstructionCreator")
  updatedInstructions Instruction[] @relation("InstructionUpdater")
  instructionAttachments InstructionAttachment[] @relation("InstructionAttachmentUploader")
  instructionCardLinks CardInstruction[] @relation("CardInstructionCreator")
  createdComponents Component[] @relation("ComponentCreator")
  updatedComponents Component[] @relation("ComponentUpdater")
  componentCardLinks CardComponent[] @relation("CardComponentCreator")
  componentDataSourceLinks DataSourceComponent[] @relation("DataSourceComponentCreator")

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model DataSource {
  id          String   @id @default(uuid())
  name        String
  description String?
  website     String?
  isActive    Boolean  @default(true) @map("is_active")
  createdById String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy User   @relation(fields: [createdById], references: [id])
  cards     Card[]
  instructionLinks DataSourceInstruction[]
  componentLinks DataSourceComponent[]

  @@index([isActive])
  @@index([name])
  @@map("data_sources")
}

model Card {
  id            String       @id @default(uuid())
  publicId      String       @unique @map("public_id")
  dataSourceId  String?      @map("data_source_id")
  sprintId      String?      @map("sprint_id")
  extraTitle    String?      @map("extra_title")
  month         Int
  year          Int
  description   String?
  status        CardStatus   @default(NEW)
  priority      CardPriority @default(NORMAL)
  dueDate       DateTime?    @map("due_date") @db.Date
  executorId    String?      @map("executor_id")
  reviewerId    String?      @map("reviewer_id")
  createdById   String       @map("created_by")
  lastChangedById String?    @map("last_changed_by")
  parentId      String?      @map("parent_id")
  isLocked      Boolean      @default(false) @map("is_locked")
  isArchived    Boolean      @default(false) @map("is_archived")
  withoutResult Boolean      @default(false) @map("without_result")
  withoutSourceMaterials Boolean @default(false) @map("without_source_materials")
  cancelReason  String?      @map("cancel_reason")
  completedAt   DateTime?    @map("completed_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  dataSource    DataSource?    @relation(fields: [dataSourceId], references: [id])
  sprint        Sprint?        @relation(fields: [sprintId], references: [id])
  executor      User?          @relation("CardExecutor", fields: [executorId], references: [id])
  reviewer      User?          @relation("CardReviewer", fields: [reviewerId], references: [id])
  createdBy     User           @relation("CardCreator", fields: [createdById], references: [id])
  lastChangedBy User?          @relation("CardLastChanger", fields: [lastChangedById], references: [id])
  parent        Card?          @relation("CardHierarchy", fields: [parentId], references: [id])

  sourceMaterials SourceMaterial[]
  resultVersions  ResultVersion[]
  history         CardHistory[]
  comments        ReviewComment[]
  watchers        CardWatcher[]
  notifications   Notification[]
  pendingNotifications PendingNotification[]
  children        Card[]          @relation("CardHierarchy")
  instructionLinks CardInstruction[]
  componentLinks CardComponent[]

  @@index([status])
  @@index([dataSourceId])
  @@index([sprintId])
  @@index([executorId])
  @@index([reviewerId])
  @@index([createdById])
  @@index([dueDate])
  @@index([priority])
  @@index([year, month])
  @@index([isArchived])
  @@index([isLocked])
  @@index([parentId])
  @@map("cards")
}

model Sprint {
  id        String       @id @default(uuid())
  name      String       @unique
  startDate DateTime     @map("start_date") @db.Date
  endDate   DateTime     @map("end_date") @db.Date
  status    SprintStatus @default(IN_PROGRESS)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  cards Card[]

  @@index([status])
  @@index([startDate, endDate])
  @@map("sprints")
}

model SourceMaterial {
  id           String       @id @default(uuid())
  cardId       String       @map("card_id")
  materialType MaterialType @map("material_type")
  title        String
  description  String?
  // FILE fields
  filePath     String?      @map("file_path")
  fileName     String?      @map("file_name")
  fileSize     BigInt?      @map("file_size")
  mimeType     String?      @map("mime_type")
  fileHash     String?      @map("file_hash")
  // EXTERNAL_LINK fields
  externalUrl  String?      @map("external_url")
  uploadedById String       @map("uploaded_by")
  createdAt    DateTime     @default(now()) @map("created_at")

  card       Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  uploadedBy User @relation(fields: [uploadedById], references: [id])

  @@index([cardId])
  @@map("source_materials")
}

model ResultVersion {
  id            String     @id @default(uuid())
  cardId        String     @map("card_id")
  versionNumber Int        @map("version_number")
  createdById   String     @map("created_by")
  createdAt     DateTime   @default(now()) @map("created_at")
  comment       String?
  statusContext String?    @map("status_context")
  isCurrent     Boolean    @default(true) @map("is_current")

  card      Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  createdBy User         @relation(fields: [createdById], references: [id])
  items     ResultItem[]
  comments  ReviewComment[]

  @@unique([cardId, versionNumber])
  @@index([cardId])
  @@index([isCurrent])
  @@map("result_versions")
}

model ResultItem {
  id              String       @id @default(uuid())
  resultVersionId String       @map("result_version_id")
  itemType        MaterialType @map("item_type")
  title           String
  description     String?
  // FILE fields
  filePath        String?      @map("file_path")
  fileName        String?      @map("file_name")
  fileSize        BigInt?      @map("file_size")
  mimeType        String?      @map("mime_type")
  fileHash        String?      @map("file_hash")
  // EXTERNAL_LINK fields
  externalUrl     String?      @map("external_url")
  createdAt       DateTime     @default(now()) @map("created_at")

  resultVersion ResultVersion @relation(fields: [resultVersionId], references: [id], onDelete: Cascade)

  @@index([resultVersionId])
  @@map("result_items")
}

model CardHistory {
  id         String        @id @default(uuid())
  cardId     String        @map("card_id")
  userId     String?       @map("user_id")
  actionType HistoryAction @map("action_type")
  oldValue   Json?         @map("old_value")
  newValue   Json?         @map("new_value")
  comment    String?
  createdAt  DateTime      @default(now()) @map("created_at")

  card Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([cardId])
  @@index([userId])
  @@index([actionType])
  @@index([createdAt])
  @@map("card_history")
}

model CardWatcher {
  id        String   @id @default(uuid())
  cardId    String   @map("card_id")
  userId    String   @map("user_id")
  source    WatchSource @default(MANUAL)
  createdAt DateTime @default(now()) @map("created_at")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cardId, userId])
  @@index([cardId])
  @@index([userId])
  @@map("card_watchers")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  cardId    String?          @map("card_id")
  adminRequestId String?     @map("admin_request_id")
  actorId   String?          @map("actor_id")
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user  User  @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  card  Card? @relation(fields: [cardId], references: [id], onDelete: Cascade)
  adminRequest AdminRequest? @relation(fields: [adminRequestId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id])

  @@index([userId])
  @@index([cardId])
  @@index([adminRequestId])
  @@index([actorId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model PendingNotification {
  id             String           @id @default(uuid())
  userId         String           @map("user_id")
  cardId         String?          @map("card_id")
  adminRequestId String?          @map("admin_request_id")
  actorId        String?          @map("actor_id")
  type           NotificationType
  title          String
  message        String
  createdAt      DateTime         @default(now()) @map("created_at")

  user         User          @relation("PendingNotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  card         Card?         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  adminRequest AdminRequest? @relation(fields: [adminRequestId], references: [id], onDelete: Cascade)
  actor        User?         @relation("PendingNotificationActor", fields: [actorId], references: [id])

  @@index([userId])
  @@index([cardId])
  @@index([adminRequestId])
  @@index([actorId])
  @@index([createdAt])
  @@map("pending_notifications")
}

model NotificationEmailSettings {
  id         String   @id @default("default")
  isEnabled  Boolean  @default(false) @map("is_enabled")
  host       String?
  port       Int?
  secure     Boolean  @default(false)
  username   String?
  password   String?
  fromEmail  String?  @map("from_email")
  fromName   String?  @map("from_name")
  replyTo    String?  @map("reply_to")
  updatedById String? @map("updated_by")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  updatedBy User? @relation("NotificationEmailSettingsUpdatedBy", fields: [updatedById], references: [id])

  @@index([isEnabled])
  @@index([updatedById])
  @@map("notification_email_settings")
}

model AdminRequest {
  id               String             @id @default(uuid())
  publicId         String             @unique @map("public_id")
  description      String
  status           AdminRequestStatus @default(NEW)
  createdById      String             @map("created_by")
  completedById    String?            @map("completed_by")
  rejectedById     String?            @map("rejected_by")
  completionComment String?           @map("completion_comment")
  rejectionComment String?            @map("rejection_comment")
  completedAt      DateTime?          @map("completed_at")
  rejectedAt       DateTime?          @map("rejected_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  createdBy    User                 @relation("AdminRequestCreator", fields: [createdById], references: [id])
  completedBy  User?                @relation("AdminRequestCompleter", fields: [completedById], references: [id])
  rejectedBy   User?                @relation("AdminRequestRejector", fields: [rejectedById], references: [id])
  links        AdminRequestLink[]
  messages     AdminRequestMessage[]
  notifications Notification[]
  pendingNotifications PendingNotification[]

  @@index([status])
  @@index([createdById])
  @@index([completedById])
  @@index([rejectedById])
  @@index([createdAt])
  @@map("admin_requests")
}

model AdminRequestLink {
  id        String   @id @default(uuid())
  requestId String   @map("request_id")
  url       String
  createdAt DateTime @default(now()) @map("created_at")

  request AdminRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("admin_request_links")
}

model AdminRequestMessage {
  id        String   @id @default(uuid())
  requestId String   @map("request_id")
  authorId  String   @map("author_id")
  text      String
  createdAt DateTime @default(now()) @map("created_at")

  request AdminRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  author  User         @relation(fields: [authorId], references: [id])

  @@index([requestId])
  @@index([authorId])
  @@index([createdAt])
  @@map("admin_request_messages")
}

model ReviewComment {
  id              String   @id @default(uuid())
  cardId          String   @map("card_id")
  authorId        String   @map("author_id")
  resultVersionId String?  @map("result_version_id")
  text            String
  createdAt       DateTime @default(now()) @map("created_at")

  card          Card           @relation(fields: [cardId], references: [id], onDelete: Cascade)
  author        User           @relation(fields: [authorId], references: [id])
  resultVersion ResultVersion? @relation(fields: [resultVersionId], references: [id])

  @@index([cardId])
  @@index([authorId])
  @@map("review_comments")
}

model InstructionFolder {
  id          String   @id @default(uuid())
  name        String
  parentId    String?  @map("parent_id")
  createdById String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy    User          @relation("InstructionFolderCreator", fields: [createdById], references: [id])
  parent       InstructionFolder? @relation("InstructionFolderTree", fields: [parentId], references: [id])
  children     InstructionFolder[] @relation("InstructionFolderTree")
  instructions Instruction[]

  @@unique([parentId, name])
  @@index([name])
  @@index([parentId])
  @@index([createdById])
  @@map("instruction_folders")
}

model Instruction {
  id          String            @id @default(uuid())
  publicId    String            @unique @map("public_id")
  title       String
  summary     String?
  contentHtml String            @map("content_html")
  status      InstructionStatus @default(DRAFT)
  folderId    String?           @map("folder_id")
  createdById String            @map("created_by")
  updatedById String?           @map("updated_by")
  publishedAt DateTime?         @map("published_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  folder      InstructionFolder?      @relation(fields: [folderId], references: [id])
  createdBy   User                    @relation("InstructionCreator", fields: [createdById], references: [id])
  updatedBy   User?                   @relation("InstructionUpdater", fields: [updatedById], references: [id])
  attachments InstructionAttachment[]
  cardLinks   CardInstruction[]
  dataSourceLinks DataSourceInstruction[]

  @@index([status])
  @@index([folderId])
  @@index([createdById])
  @@index([updatedAt])
  @@map("instructions")
}

model InstructionAttachment {
  id           String   @id @default(uuid())
  instructionId String  @map("instruction_id")
  filePath     String   @map("file_path")
  fileName     String   @map("file_name")
  fileSize     BigInt   @map("file_size")
  mimeType     String?  @map("mime_type")
  fileHash     String?  @map("file_hash")
  uploadedById String   @map("uploaded_by")
  createdAt    DateTime @default(now()) @map("created_at")

  instruction Instruction @relation(fields: [instructionId], references: [id], onDelete: Cascade)
  uploadedBy  User        @relation("InstructionAttachmentUploader", fields: [uploadedById], references: [id])

  @@index([instructionId])
  @@index([uploadedById])
  @@map("instruction_attachments")
}

model CardInstruction {
  id            String   @id @default(uuid())
  cardId         String   @map("card_id")
  instructionId  String   @map("instruction_id")
  createdById    String   @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")

  card         Card        @relation(fields: [cardId], references: [id], onDelete: Cascade)
  instruction  Instruction @relation(fields: [instructionId], references: [id], onDelete: Cascade)
  createdBy    User        @relation("CardInstructionCreator", fields: [createdById], references: [id])

  @@unique([cardId, instructionId])
  @@index([cardId])
  @@index([instructionId])
  @@index([createdById])
  @@map("card_instructions")
}

model DataSourceInstruction {
  id            String   @id @default(uuid())
  dataSourceId   String   @map("data_source_id")
  instructionId  String   @map("instruction_id")
  createdById    String   @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")

  dataSource   DataSource   @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  instruction  Instruction  @relation(fields: [instructionId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("DataSourceInstructionCreator", fields: [createdById], references: [id])

  @@unique([dataSourceId, instructionId])
  @@index([dataSourceId])
  @@index([instructionId])
  @@index([createdById])
  @@map("data_source_instructions")
}

model Component {
  id          String   @id @default(uuid())
  publicId    String   @unique @map("public_id")
  name        String
  description String?
  location    String
  isArchived  Boolean  @default(false) @map("is_archived")
  createdById String   @map("created_by")
  updatedById String?  @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy User @relation("ComponentCreator", fields: [createdById], references: [id])
  updatedBy User? @relation("ComponentUpdater", fields: [updatedById], references: [id])
  cardLinks CardComponent[]
  dataSourceLinks DataSourceComponent[]

  @@index([isArchived])
  @@index([name])
  @@index([createdById])
  @@index([updatedAt])
  @@map("components")
}

model CardComponent {
  id          String   @id @default(uuid())
  cardId       String   @map("card_id")
  componentId  String   @map("component_id")
  createdById  String   @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")

  card       Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)
  component  Component @relation(fields: [componentId], references: [id], onDelete: Cascade)
  createdBy  User      @relation("CardComponentCreator", fields: [createdById], references: [id])

  @@unique([cardId, componentId])
  @@index([cardId])
  @@index([componentId])
  @@index([createdById])
  @@map("card_components")
}

model DataSourceComponent {
  id           String   @id @default(uuid())
  dataSourceId String   @map("data_source_id")
  componentId  String   @map("component_id")
  createdById  String   @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")

  dataSource DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  component  Component  @relation(fields: [componentId], references: [id], onDelete: Cascade)
  createdBy  User       @relation("DataSourceComponentCreator", fields: [createdById], references: [id])

  @@unique([dataSourceId, componentId])
  @@index([dataSourceId])
  @@index([componentId])
  @@index([createdById])
  @@map("data_source_components")
}
